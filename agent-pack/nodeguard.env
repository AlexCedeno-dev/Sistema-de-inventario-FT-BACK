# ─────────────────────────────────────────
#  NodeGuard Agent — .env
#  Renombra este archivo a .env
#  NUNCA subas .env a Git
# ─────────────────────────────────────────

# URL del servidor NodeGuard
# Producción con dominio propio:  https://192.168.179.6
# Red local:                      http://10.8.4.95:3006
NODEGUARD_API_URL=http://192.168.179.6:3005



# Token de autenticación
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NODEGUARD_TOKEN=local123

# Logs en consola (true/false)
DEBUG_AGENT=false

# Guardar errores en archivo (true/false) — siempre se guardan WARN y ERROR
LOG_ERRORS_FILE=false

# Intervalo de monitoreo en ms — MÍNIMO 30000 (30s)
# 10000 (10s) era el motivo principal de que frenara la laptop
INTERVALO_MONITOR_MS=60000

# Intervalo de ubicación en ms — para anti-robo considera 300000 (5 min)
INTERVALO_UBICACION_MS=3600000
